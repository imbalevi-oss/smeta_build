{
  "name": "smeta-analyzer",
  "version": "1.0.0",
  "description": "Система анализа сметной документации",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --testPathIgnorePatterns=tests/",
    "test:all": "jest",
    "test:frontend": "jest --testPathPattern=public/__tests__/",
    "test:backend": "jest --testPathPattern=tests/ --testEnvironment=node --testPathIgnorePatterns=public/",
    "test:simple": "jest public/__tests__/simple.test.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.6",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "babel-jest": "^29.7.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/",
      "/public/__tests__/integration/",
      "/public/__tests__/modules/file-handler.test.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/public/__tests__/setup.js"
    ],
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "identity-obj-proxy"
    },
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "moduleDirectories": [
      "node_modules",
      "public"
    ]
  }
}
